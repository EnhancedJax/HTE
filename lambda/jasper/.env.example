# MiniMax (required)
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# Optional MiniMax
MINIMAX_EMBED_MODEL=embo-01
MINIMAX_EMBED_BATCH_SIZE=32

# Pinecone (required)
PINECONE_API_KEY=

# Optional Pinecone – set PINECONE_DIM to your MiniMax embedding dimension (e.g. 1536)
PINECONE_INDEX_NAME=child_online_safety_docs
PINECONE_ENVIRONMENT=us-east-1
PINECONE_DIM=1536
