# Hugging Face (required for embedding)
HF_TOKEN=

# Optional Hugging Face – default model: sentence-transformers/all-MiniLM-L6-v2 (dim 384)
HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_EMBED_BATCH_SIZE=32

# Pinecone (required) – cloud service, no host URL needed; only API key
PINECONE_API_KEY=

# Optional Pinecone – PINECONE_DIM must match embedding model (e.g. 384 for MiniLM-L6-v2)
PINECONE_INDEX_NAME=hugging-face-v1
PINECONE_ENVIRONMENT=us-east-1
PINECONE_DIM=384
